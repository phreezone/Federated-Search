# --- AWS Credentials & Config for Federated S3 scripts ---
# Copy this file to `.env` and fill in the real values.
# DO NOT commit the real `.env` file to version control.

# The S3 bucket created by the FederatedS3.yaml CloudFormation template.
# Look this up in the CloudFormation 'Outputs' tab (BucketName output).
BUCKET_NAME=xsiam-federated-waf-YOUR_ACCOUNT_ID

# AWS IAM user access key ID (format: AKIA... for long-term keys).
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID_HERE

# AWS IAM user secret access key. Keep this secret.
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY_HERE
